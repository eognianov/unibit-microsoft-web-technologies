@model IEnumerable<RecipeVaultWithDb.Models.Recipe>

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">Добре дошли в RecipeVault</h1>
        <p class="lead text-muted">Открийте вкусни рецепти за всеки повод</p>
        <a asp-controller="Home" asp-action="Index"
           class="btn btn-warning btn-lg px-4 fw-semibold">
            Разгледай всички рецепти
        </a>
    </div>

    <h4 class="mb-4 fw-semibold">Последно добавени</h4>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var recipe in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">

                    @if (!string.IsNullOrEmpty(recipe.ImageUrl))
                    {
                        <img src="@recipe.ImageUrl"
                             class="card-img-top"
                             alt="@recipe.Title"
                             style="height: 200px; object-fit: cover;">
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center bg-light"
                             style="height: 200px;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48"
                                 fill="#adb5bd" viewBox="0 0 16 16">
                                <path d="M8.522 0C5.17 0 4.31.705 4.31 2.486v.91H2.98C1.333 3.396 0 4.73 0 6.378v6.245C0 14.268 1.332 15.6 2.98 15.6h10.04c1.648 0 2.98-1.332 2.98-2.977V6.378c0-1.648-1.332-2.982-2.98-2.982h-1.33v-.91C11.69.705 10.83 0 8.522 0zm0 1.2c1.997 0 2.968.527 2.968 1.286v.91H5.51v-.91c0-.759.971-1.286 2.968-1.286h.044zM2.98 4.596h10.04c.981 0 1.78.799 1.78 1.782v6.245c0 .983-.799 1.777-1.78 1.777H2.98c-.981 0-1.78-.794-1.78-1.777V6.378c0-.983.799-1.782 1.78-1.782z"/>
                            </svg>
                        </div>
                    }

                    <div class="card-body d-flex flex-column gap-2">

                        <div class="d-flex align-items-start justify-content-between gap-2">
                            <h5 class="card-title mb-0 fw-semibold">@recipe.Title</h5>
                            <span class="badge text-bg-warning text-dark flex-shrink-0">@recipe.Category</span>
                        </div>

                        <div class="d-flex flex-wrap gap-3 text-muted small">
                            @if (recipe.CookTimeMinutes.HasValue)
                            {
                                <span>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                         fill="currentColor" class="me-1" viewBox="0 0 16 16">
                                        <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/>
                                        <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/>
                                    </svg>
                                    @recipe.CookTimeMinutes мин.
                                </span>
                            }
                            <span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                     fill="currentColor" class="me-1" viewBox="0 0 16 16">
                                    <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
                                    <path fill-rule="evenodd" d="M5.216 14A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1h4.216z"/>
                                    <path d="M4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z"/>
                                </svg>
                                @recipe.Servings порции
                            </span>
                            <span class="ms-auto">
                                @recipe.CreatedAt.ToString("dd.MM.yyyy")
                            </span>
                        </div>

                        <p class="card-text text-muted small flex-grow-1"
                           style="display: -webkit-box; -webkit-line-clamp: 3;
                                  -webkit-box-orient: vertical; overflow: hidden;">
                            @recipe.Instructions
                        </p>

                    </div>

                    <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3">
                        <a href="#"
                           class="btn btn-outline-warning w-100 fw-semibold">
                            Виж рецептата
                        </a>
                    </div>

                </div>
            </div>
        }
    </div>

</div>